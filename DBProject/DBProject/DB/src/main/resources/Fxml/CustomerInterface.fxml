<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ButtonBar?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>

<AnchorPane prefHeight="458.0" prefWidth="963.0" stylesheets="@../CSS/Styles.CSS" xmlns="http://javafx.com/javafx/20" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.db.CustomerController">
   <children>
      <VBox layoutX="22.0" layoutY="85.0" prefHeight="290.0" prefWidth="222.0" spacing="5.0">
         <children>
            <Text strokeType="OUTSIDE" strokeWidth="0.0" text="Customer Name" />
            <TextField fx:id="customerName" />
            <Text strokeType="OUTSIDE" strokeWidth="0.0" text="Customer Phone" />
            <TextField fx:id="customerPhone" />
            <Text strokeType="OUTSIDE" strokeWidth="0.0" text="Customer Address" />
            <TextField fx:id="customerAddress" />
            <Text strokeType="OUTSIDE" strokeWidth="0.0" text="Customer Bank Account" />
            <TextField fx:id="customerAccount" />
            <Text strokeType="OUTSIDE" strokeWidth="0.0" text="Customer Date Of Birth" />
            <DatePicker fx:id="customerDOB" promptText="Enter DOB" />
         </children>
         <opaqueInsets>
            <Insets />
         </opaqueInsets>
      </VBox>
      <TableView fx:id="talble" layoutX="253.0" layoutY="107.0" onMouseClicked="#getData" prefHeight="250.0" prefWidth="684.0">
        <columns>
          <TableColumn fx:id="cusId" prefWidth="76.79998779296875" text="Customer ID" />
          <TableColumn fx:id="cusName" prefWidth="101.59991455078125" text="Customer Name" />
            <TableColumn fx:id="cusPhone" prefWidth="103.20001220703125" text="Customer Phone" />
            <TableColumn fx:id="cusAddress" prefWidth="112.0" text="Customer Address" />
            <TableColumn fx:id="cusBankempIdAccount" prefWidth="144.800048828125" text="Customer Bank Account" />
            <TableColumn fx:id="cusDateofbirth" prefWidth="140.0" text="Customer Date Of Birth" />
        </columns>
      </TableView>
      <Label alignment="CENTER" layoutX="395.0" layoutY="41.0" text="CRUD Customer">
         <font>
            <Font size="24.0" />
         </font>
      </Label>
      <ButtonBar layoutX="215.0" layoutY="384.0" prefHeight="40.0" prefWidth="200.0">
         <buttons>
          <Button fx:id="btSave" alignment="CENTER" mnemonicParsing="false" onAction="#createCustomer" text="Insert " />
            <Button fx:id="btDelete" mnemonicParsing="false" onAction="#deleteCustomer" text="Delete" />
            <Button fx:id="btUpdate" minHeight="38.0" mnemonicParsing="false" onAction="#updateCustomer" prefHeight="38.0" prefWidth="120.0" text="Update" />
            <Button fx:id="btClear" mnemonicParsing="false" onAction="#clearField" text="Clear" />
         </buttons>
      </ButtonBar>
   </children>
</AnchorPane>
