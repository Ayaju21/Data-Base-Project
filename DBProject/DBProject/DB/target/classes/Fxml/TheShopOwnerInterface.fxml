<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ButtonBar?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>

<AnchorPane prefHeight="511.0" prefWidth="885.0" stylesheets="@../CSS/Styles.CSS" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.db.ShopOwnerController">
   <children>
      <VBox layoutX="22.0" layoutY="85.0" prefHeight="290.0" prefWidth="222.0" spacing="5.0">
         <children>
            <Text strokeType="OUTSIDE" strokeWidth="0.0" text="Owner Name" />
            <TextField fx:id="ownerName" />
            <Text strokeType="OUTSIDE" strokeWidth="0.0" text="Owner Phone" />
            <TextField fx:id="ownerPhone" />
            <Text strokeType="OUTSIDE" strokeWidth="0.0" text="Owner Address" />
            <TextField fx:id="OwnerAddress" />
            <Text strokeType="OUTSIDE" strokeWidth="0.0" text="Owner Email" />
            <TextField fx:id="OwnerEmail" />
            <Text strokeType="OUTSIDE" strokeWidth="0.0" text="Owner Date Of Birth" />
            <DatePicker fx:id="ownerDOB" promptText="Enter DOB" />
         </children>
         <opaqueInsets>
            <Insets />
         </opaqueInsets>
      </VBox>
      <TableView fx:id="talble" layoutX="253.0" layoutY="107.0" onMouseClicked="#getData" prefHeight="250.0" prefWidth="603.0">
        <columns>
          <TableColumn fx:id="ShopId" prefWidth="76.79998779296875" text="Owner ID" />
          <TableColumn fx:id="ShopName" prefWidth="94.4000244140625" text="Owner Name" />
            <TableColumn fx:id="ShopPhone" prefWidth="84.79998779296875" text="Owner Phone" />
            <TableColumn fx:id="ShopAddress" prefWidth="99.99993896484375" text="Owner Address" />
            <TableColumn fx:id="ShopEmail" prefWidth="120.00006103515625" text="Owner Email" />
            <TableColumn fx:id="ShopDateofbirth" prefWidth="123.199951171875" text="Owner Date Of Birth" />
        </columns>
      </TableView>
      <Label alignment="CENTER" layoutX="311.0" layoutY="33.0" text="CRUD The Shop Owner">
         <font>
            <Font size="24.0" />
         </font>
      </Label>
      <ButtonBar layoutX="168.0" layoutY="400.0" prefHeight="40.0" prefWidth="200.0">
         <buttons>
          <Button fx:id="btSave" alignment="CENTER" mnemonicParsing="false" onAction="#createOwner" text="Insert " />
            <Button fx:id="btDelete" mnemonicParsing="false" onAction="#deleteOwner" text="Delete" />
            <Button fx:id="btUpdate" minHeight="38.0" mnemonicParsing="false" onAction="#updateOwner" prefHeight="38.0" prefWidth="120.0" text="Update" />
            <Button fx:id="btClear" mnemonicParsing="false" onAction="#clearField" text="Clear" />
         </buttons>
      </ButtonBar>
   </children>
</AnchorPane>
