<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ButtonBar?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>

<AnchorPane prefHeight="451.0" prefWidth="967.0" stylesheets="@../CSS/Styles.CSS" xmlns="http://javafx.com/javafx/20" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.db.SupplierCompanyController">
   <children>
      <VBox layoutX="24.0" layoutY="116.0" prefHeight="219.0" prefWidth="222.0" spacing="5.0">
         <children>
            <Text strokeType="OUTSIDE" strokeWidth="0.0" text="Supplier Company Name" />
            <TextField fx:id="suplName" />
            <Text strokeType="OUTSIDE" strokeWidth="0.0" text="Supplier Company Phone" />
            <TextField fx:id="suplPhone" />
            <Text strokeType="OUTSIDE" strokeWidth="0.0" text="Supplier Company Address" />
            <TextField fx:id="suplAddress" />
            <Text strokeType="OUTSIDE" strokeWidth="0.0" text="Supplier Company Email" />
            <TextField fx:id="suplEmail" />
         </children>
         <opaqueInsets>
            <Insets />
         </opaqueInsets>
      </VBox>
      <TableView fx:id="talble" layoutX="259.0" layoutY="106.0" onMouseClicked="#getData" prefHeight="219.0" prefWidth="686.0">
         <columns>
          <TableColumn fx:id="supId" prefWidth="47.20002746582031" text=" ID " />
          <TableColumn fx:id="supName" prefWidth="150.4000244140625" text="Supplier Company Name" />
            <TableColumn fx:id="supPhone" prefWidth="165.60003662109375" text="Supplier Company Phone" />
            <TableColumn fx:id="subAddress" prefWidth="167.20001220703125" text="Supplier Company Address" />
            <TableColumn fx:id="subEmail" prefWidth="148.0" text="Supplier Company Email" />
         </columns>
      </TableView>
      <Label alignment="CENTER" layoutX="352.0" layoutY="35.0" text="CRUD Supplier Company">
         <font>
            <Font size="24.0" />
         </font>
      </Label>
      <ButtonBar layoutX="246.0" layoutY="372.0" prefHeight="40.0" prefWidth="200.0">
         <buttons>
          <Button fx:id="btSave" alignment="CENTER" mnemonicParsing="false" onAction="#createSupplierCompany" text="Insert " />
            <Button fx:id="btDelete" mnemonicParsing="false" onAction="#deleteSupplierCompany" text="Delete" />
            <Button fx:id="btUpdate" minHeight="38.0" mnemonicParsing="false" onAction="#updateSupplierCompany" prefHeight="38.0" prefWidth="120.0" text="Update" />
            <Button fx:id="btClear" mnemonicParsing="false" onAction="#clearField" text="Clear" />
         </buttons>
      </ButtonBar>
   </children>
</AnchorPane>
