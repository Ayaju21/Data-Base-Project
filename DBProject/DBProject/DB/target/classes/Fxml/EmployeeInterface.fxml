<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ButtonBar?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>

<AnchorPane prefHeight="519.0" prefWidth="1094.0" stylesheets="@../CSS/Styles.CSS" xmlns="http://javafx.com/javafx/20" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.db.EmployeeController">
    <children>
        <VBox layoutX="22.0" layoutY="85.0" prefHeight="372.0" prefWidth="222.0" spacing="5.0">
            <children>
                <Text strokeType="OUTSIDE" strokeWidth="0.0" text="Employee Name " />
                <TextField fx:id="employee_name" />
                <Text strokeType="OUTSIDE" strokeWidth="0.0" text="Employee Phone" />
                <TextField fx:id="employee_phone" />
                <Text strokeType="OUTSIDE" strokeWidth="0.0" text="Employee Address" />
                <TextField fx:id="emoployee_Address" />
                <Text strokeType="OUTSIDE" strokeWidth="0.0" text="Employee Email" />
                <TextField fx:id="employee_Email" />
                <Text strokeType="OUTSIDE" strokeWidth="0.0" text="Employee Date Of Birth" />
                <DatePicker fx:id="employee_DOB" promptText="Enter DOB" />
                <Text strokeType="OUTSIDE" strokeWidth="0.0" text="Employee Hourly Wage" />
                <TextField fx:id="employee_Hourly_Wage" />
            </children>
            <opaqueInsets>
                <Insets />
            </opaqueInsets>
        </VBox>
        <TableView fx:id="talble" layoutX="256.0" layoutY="95.0" onMouseClicked="#getData" prefHeight="314.0" prefWidth="801.0">
            <columns>
                <TableColumn fx:id="empId" prefWidth="88.800048828125" text="Employee ID" />
                <TableColumn fx:id="empName" prefWidth="103.20001220703125" text="Employee Name " />
                <TableColumn fx:id="empPhone" prefWidth="99.20001220703125" text="Employee Phone" />
                <TableColumn fx:id="empAddress" prefWidth="108.800048828125" text="Employee Address" />
                <TableColumn fx:id="empEmail" prefWidth="100.79998779296875" text="Employee Email" />
                <TableColumn fx:id="empDateofbirth" minWidth="7.199951171875" prefWidth="146.4000244140625" text="Employee Date Of Birth" />
                <TableColumn fx:id="proBrand" minWidth="0.0" prefWidth="0.0" text="Brand" />
            <TableColumn fx:id="empHourly_wage" minWidth="7.199951171875" prefWidth="146.4000244140625" text="Employee Hourly Wage" />
            </columns>
        </TableView>
        <Label alignment="CENTER" layoutX="455.0" layoutY="26.0" text="CRUD Employees">
            <font>
                <Font size="24.0" />
            </font>
        </Label>
        <ButtonBar layoutX="281.0" layoutY="437.0" prefHeight="40.0" prefWidth="200.0">
            <buttons>
                <Button fx:id="btSave" alignment="CENTER" mnemonicParsing="false" onAction="#createEmployee" text="Insert " />
                <Button fx:id="btDelete" mnemonicParsing="false" onAction="#deleteEmployee" text="Delete" />
                <Button fx:id="btUpdate" minHeight="38.0" mnemonicParsing="false" onAction="#updateEmployee" prefHeight="38.0" prefWidth="120.0" text="Update" />
                <Button fx:id="btClear" mnemonicParsing="false" onAction="#clearField" text="Clear" />
            </buttons>
        </ButtonBar>
    </children>
</AnchorPane>
